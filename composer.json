{
    "name": "dnsinyukov/google-indexing-api",
    "description": "The package allows you to use the Google API for indexing allows you to directly notify Google when pages are added or removed.",
    "autoload": {
        "psr-4": {
            "Dnsinyukov\\IndexingApi\\": "src/"
        }
    },
    "authors": [
        {
            "name": "dnsinyukov",
            "email": "dnsinyukov@gmail.com"
        }
    ],
    "type": "library",
    "minimum-stability": "dev",
    "require": {
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.2|^8.2",
        "google/apiclient": "^2.0",
        "vlucas/phpdotenv": "^5.6@dev"
    },
    "require-dev": {
        "symfony/var-dumper": "7.3.x-dev"
    }
}
